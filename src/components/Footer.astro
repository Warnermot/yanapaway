---
const columns = [
	{
		title: 'Contactos',
		items: ['+123 654 987', '877 The Bronx, NY', '14568, USA'],
	},
	{
		title: 'Ayuda',
		items: ['Shipping', 'Returns', 'Sizing'],
	},
	{
		title: 'Contenido',
		items: ['All Products', 'Bedroom', 'Dinning Room'],
	},
	{
		title: 'Legal Stuff',
		items: ['Shipping & Delivery', 'Terms & Conditions', 'Privacy & Policy'],
	},
];
---

<footer class="site-footer">
	<div class="wrapper">
		<div class="social-row">
			<a href="#" aria-label="Facebook" class="social-icon">
				<svg viewBox="0 0 24 24" fill="currentColor"
					><path
						d="M13.5 21v-7.6h2.55l.38-2.96h-2.93V8.55c0-.86.24-1.44 1.47-1.44h1.57V4.46c-.27-.04-1.2-.12-2.28-.12-2.26 0-3.8 1.38-3.8 3.9v2.18H8v2.96h2.46V21h3.04Z"
					></path></svg
				>
			</a>
			<a href="#" aria-label="Instagram" class="social-icon">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
					><rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect><circle
						cx="12"
						cy="12"
						r="4"></circle><circle cx="17.2" cy="6.8" r="0.6" fill="currentColor"
						stroke="none"></circle></svg
				>
			</a>
			<a href="#" aria-label="LinkedIn" class="social-icon">
				<svg viewBox="0 0 24 24" fill="currentColor"
					><path
						d="M6.94 8.5H4.02V20h2.92V8.5ZM5.48 4c-.99 0-1.65.65-1.65 1.5 0 .84.64 1.5 1.62 1.5h.02c1.01 0 1.65-.66 1.65-1.5C7.1 4.65 6.48 4 5.48 4ZM20 20h-2.92v-6.15c0-1.5-.54-2.52-1.9-2.52-1.03 0-1.65.7-1.92 1.36-.1.24-.12.57-.12.9V20H10.2s.04-10.72 0-11.5h2.92v1.63c.39-.6 1.08-1.45 2.63-1.45 1.92 0 3.36 1.25 3.36 3.94V20Z"
					></path></svg
				>
			</a>
			<a href="#" aria-label="Dribbble" class="social-icon">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
					><circle cx="12" cy="12" r="8.5"></circle><path
						d="M4.5 9.5c4.5 1.5 10 1.2 14.2-1M4 15.5c5-1.6 11-1 15 1.8M9 3.8c3 4.2 4.6 9.3 4 16.4"
					></path></svg
				>
			</a>
			<a href="#" aria-label="Twitter" class="social-icon">
				<svg viewBox="0 0 24 24" fill="currentColor"
					><path
						d="M20.5 6.4c-.6.27-1.24.45-1.9.53a3.3 3.3 0 0 0 1.45-1.83 6.6 6.6 0 0 1-2.1.8 3.3 3.3 0 0 0-5.63 3 9.36 9.36 0 0 1-6.8-3.45 3.3 3.3 0 0 0 1.02 4.4c-.53-.02-1.03-.16-1.47-.4v.04a3.3 3.3 0 0 0 2.65 3.24c-.48.13-1 .16-1.5.06a3.3 3.3 0 0 0 3.08 2.3A6.62 6.62 0 0 1 3 16.6a9.32 9.32 0 0 0 5.05 1.48c6.06 0 9.38-5.02 9.38-9.38l-.01-.43c.64-.46 1.2-1.04 1.64-1.7Z"
					></path></svg
				>
			</a>
		</div>

		<div class="footer-columns">
			{
				columns.map((column) => (
					<div class="footer-column">
						<h3>{column.title}</h3>
						<ul>
							{column.items.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--color-footer);
		color: var(--color-cream);
		padding-block: 3.5rem 2.5rem;
	}

	.social-row {
		display: flex;
		justify-content: center;
		gap: 1.75rem;
		margin-bottom: 3rem;
	}

	.social-icon {
		display: inline-flex;
		color: var(--color-cream);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.social-icon svg {
		width: 22px;
		height: 22px;
	}

	.social-icon:hover {
		color: var(--color-green-light);
	}

	.footer-columns {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
		max-width: 900px;
		margin-inline: auto;
	}

	.footer-column h3 {
		font-size: 1rem;
		font-weight: 600;
		margin-bottom: 1rem;
	}

	.footer-column ul {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.footer-column li {
		font-size: 0.9rem;
		color: var(--color-cream-dark);
	}

	@media (max-width: 700px) {
		.footer-columns {
			grid-template-columns: repeat(2, 1fr);
			gap: 2rem 1.5rem;
		}
	}
</style>
