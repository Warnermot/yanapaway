---
const items = Array.from({ length: 6 }, (_, index) => ({
	title: 'Lorem ipsum dolor sit',
	cta: 'Lorem',
	id: index,
}));
---

<section class="content-section" id="recursos">
	<div class="wrapper">
		<h2 class="section-heading">contenido</h2>
		<div class="content-grid">
			{
				items.map((item) => (
					<article class="content-card">
						<div class="card-image img-placeholder" />
						<div class="card-body">
							<p class="card-title">{item.title}</p>
							<a href="#" class="pill-btn card-cta">
								{item.cta}
							</a>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.content-section {
		padding-block: 4.5rem;
	}

	.content-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.content-card {
		background: white;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 6px 20px rgba(26, 26, 23, 0.06);
	}

	.card-image {
		aspect-ratio: 4 / 3;
	}

	.card-body {
		padding: 1.25rem 1.5rem 1.75rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		text-align: center;
	}

	.card-title {
		font-size: 0.9rem;
		color: var(--color-ink-soft);
	}

	.card-cta {
		background: var(--color-orange);
		color: white;
		padding: 0.55rem 2.5rem;
		font-weight: 500;
	}

	@media (max-width: 860px) {
		.content-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 540px) {
		.content-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
