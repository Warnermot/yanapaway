---
const navLinks = [
	{ label: 'Inicio', href: '#inicio' },
	{ label: 'Recursos', href: '#recursos' },
	{ label: 'Asistente', href: '#asistente' },
	{ label: 'Blog', href: '#blog' },
	{ label: 'Contratos', href: '#contactos' },
];
---

<header class="site-header">
	<div class="navbar wrapper">
		<a class="logo" href="/">yanapaway</a>
		<ul class="nav-links">
			{
				navLinks.map((link) => (
					<li>
						<a href={link.href}>{link.label}</a>
					</li>
				))
			}
		</ul>
		<a class="sos-badge" href="#sos" aria-label="Ayuda de emergencia SOS">SOS</a>
	</div>

	<div class="hero">
		<div class="hero-content wrapper">
			<h1>No estás sola. No es tu culpa.</h1>
			<p>Encuentra apoyo seguro, ahora mismo</p>
			<div class="hero-actions">
				<input type="text" class="hero-input" placeholder="Lorem ipsum dolor sit amet" />
				<button type="button" class="hero-input hero-button">Lorem ipsum</button>
			</div>
		</div>
	</div>
</header>

<style>
	.site-header {
		background: var(--color-cream);
	}

	.navbar {
		display: flex;
		align-items: center;
		gap: 2rem;
		padding-block: 1.5rem;
	}

	.logo {
		font-size: 1.25rem;
		font-weight: 600;
		text-decoration: none;
		color: var(--color-ink);
	}

	.nav-links {
		display: flex;
		gap: 1.75rem;
		margin-inline-start: auto;
	}

	.nav-links a {
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--color-ink);
		transition: color 0.2s ease;
	}

	.nav-links a:hover {
		color: var(--color-green);
	}

	.sos-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.85rem;
		letter-spacing: 0.04em;
		color: var(--color-red);
		border: 3px double var(--color-red);
		padding: 0.3rem 0.6rem;
		border-radius: 4px;
		transform: rotate(-4deg);
		background: var(--color-cream);
	}

	.hero {
		background: var(--color-green);
		color: white;
		padding-block: 3.5rem;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.75rem;
		max-width: 640px;
	}

	.hero h1 {
		font-size: clamp(1.75rem, 1.3rem + 2vw, 2.5rem);
		font-weight: 600;
		line-height: 1.25;
	}

	.hero p {
		font-size: 1.05rem;
		opacity: 0.92;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 1rem;
		width: 100%;
	}

	.hero-input {
		flex: 1 1 220px;
		min-width: 200px;
		border: none;
		border-radius: 999px;
		padding: 0.9rem 1.4rem;
		font-family: inherit;
		font-size: 0.95rem;
		background: var(--color-cream-dark);
		color: var(--color-ink-soft);
	}

	.hero-button {
		flex: 0 0 auto;
		cursor: pointer;
		font-weight: 500;
		transition: background 0.2s ease;
	}

	.hero-button:hover {
		background: white;
	}

	@media (max-width: 720px) {
		.navbar {
			flex-wrap: wrap;
			gap: 1rem;
		}

		.nav-links {
			order: 3;
			width: 100%;
			flex-wrap: wrap;
			gap: 1rem;
			margin-inline-start: 0;
		}
	}
</style>
